# ============================================================
#  resibot - environment configuration
#  مقادیر زیر هنگام نصب (install.sh) پرسیده می‌شوند.
# ============================================================

# --- Telegram ---
# توکن ربات از @BotFather
BOT_TOKEN=

# آیدی عددی ادمین اصلی (فقط همین شخص دسترسی کامل دارد)
ADMIN_ID=7084999553

# --- 3x-ui Panel ---
# آدرس کامل پنل همراه با base path، مثال:
#   https://panel.example.com:2053/abcDEF
PANEL_BASE_URL=

# روش احراز هویت پنل:
# توصیه: یوزرنیم/پسورد پنل را حتماً بگذار (برای مدیریت اوتباند و تنظیمات لازم است).
# توکن API اختیاری است و فقط روی مسیرهای /panel/api/* استفاده می‌شود.
PANEL_API_TOKEN=
PANEL_USERNAME=
PANEL_PASSWORD=

# --- آدرس سروری که داخل لینک کانفیگ به مشتری داده می‌شود ---
# (معمولا IP یا دامنه‌ی سرور پنل). در ربات هم قابل تغییر است.
SERVER_IP=

# --- مشخصات stream اینباند VLESS xhttp TLS ---
# این مقادیر داخل env ست می‌شوند و در ربات هم قابل ویرایش‌اند.
INBOUND_SNI=irsp.mahandevs.com
INBOUND_HOST=irsp.mahandevs.com
INBOUND_PATH=/get
INBOUND_ALPN=h2
INBOUND_FINGERPRINT=chrome
# حداکثر بایت هر POST در xhttp
INBOUND_SC_MAX_EACH_POST_BYTES=5000000
# بازه پورت تصادفی برای اینباندها
PORT_RANGE_MIN=10000
PORT_RANGE_MAX=60000

# --- فالبک‌های اختیاری وقتی /panel/setting/all در دسترس نیست ---
# مسیر فایل گواهی و کلید پنل (همان مقادیر «Set as panel»)
PANEL_CERT_FILE=
PANEL_KEY_FILE=
# تنظیمات سرور اشتراک برای ساخت لینک ساب
SUB_PORT=2096
SUB_PATH=/sub/
SUB_SECURE=true

# --- SmartProxy (اوتباند) ---
SMARTPROXY_HOST=proxy.smartproxy.net
SMARTPROXY_PORT=3120
# قسمت ثابت یوزرنیم تا قبل از area/session
# مثال کامل: smart-myrRsidFntpraGNS_area-GB_life-120_session-PzZyPXwOY
# اینجا فقط بخش پایه را بگذار: smart-myrRsidFntpraGNS
SMARTPROXY_USER_BASE=smart-myrRsidFntpraGNS
SMARTPROXY_PASSWORD=mDQAas441edehe55
# مدت ماندگاری IP به دقیقه (1 تا 1440)
SMARTPROXY_LIFE=120

# --- اوتباند رزیدنتال ۲ ---
# پارامترهای لوکیشن/سشن داخل رشته‌ی password کدگذاری می‌شوند، نه username.
# نمونه‌ی کامل password: x1NFN2nK3r2w2umj_country-gb_session-YkaWtTRI_lifetime-168h
IPROYAL_HOST=geo.iproyal.com
IPROYAL_PORT=12321
IPROYAL_USERNAME=zUulUCSUneWHTauW
# فقط بخش پایه‌ی پسورد (بدون country/session/lifetime):
IPROYAL_PASSWORD=x1NFN2nK3r2w2umj
# مدت ماندگاری IP به دقیقه (1 تا 10080 = ۷ روز)
IPROYAL_LIFE=1440

# --- ربات کمکی مشتری (اختیاری) ---
# توکن ربات تلگرام کمکی که مشتری با آن IP سرویسش را تغییر می‌دهد.
# سرویس آن با systemd: resibot-customer اجرا می‌شود.
CUSTOMER_BOT_TOKEN=

# --- قوانین فروش ---
# حداقل حجم خرید به گیگابایت (در ربات هم قابل ویرایش است)
MIN_VOLUME_GB=5
# حداقل حجم تمدید به گیگابایت
RENEW_MIN_VOLUME_GB=5
# مدت اعتبار هر کانفیگ به روز (در هر تمدید هم همین مقدار اضافه می‌شود)
CONFIG_DURATION_DAYS=30

# --- برند ---
BRAND_NAME=w2f
BRAND_FULL=Way To Freedom

# --- قیمت‌ها (هر گیگابایت) — واحد در WALLET_CURRENCY ---
# رزیدنتال عادی (مشتری) و همکار (ارزان‌تر)؛ همگی در ربات قابل ویرایش‌اند.
PRICE_PER_GB=2.9
RESELLER_PRICE_PER_GB=2.0
# رزیدنتال ۲ (IPRoyal) — واحد دلار
RESIDENTIAL2_PRICE_PER_GB=12
RESIDENTIAL2_RESELLER_PRICE_PER_GB=10
# V2Ray (پنل بعداً اضافه می‌شود)
V2RAY_PRICE_PER_GB=1.5
V2RAY_RESELLER_PRICE_PER_GB=1.0
# حداقل موجودی لازم برای همکار v2ray (پیش‌پرداخت)
RESELLER_MIN_BALANCE=5000000

# --- نمایش/مخفی‌سازی بخش‌ها (1=نمایش، 0=مخفی؛ در ربات هم قابل تغییر است) ---
SHOW_PARTNERSHIP=1
SHOW_RESIDENTIAL=1
SHOW_RESIDENTIAL2=1
SHOW_V2RAY=1

# --- کیف پول و پرداخت (NowPayments) ---
# واحد نمایش کیف پول و قیمت‌ها
WALLET_CURRENCY=تومان
# نرخ تبدیل هر دلار/تتر به تومان (در ربات هم قابل ویرایش است)
TOMAN_PER_USD=175000
NOWPAYMENTS_API_KEY=WYVJA75-C4AMHZA-GTH583W-MD9GR9R
NOWPAYMENTS_IPN_SECRET=A8+fRQbTiIxxmmQcMa20zBT7sg1BcTN+
NOWPAYMENTS_PUBLIC_KEY=62869df6-47c1-4cf5-a446-47c405fccbab
# ارز قیمت‌گذاری در درگاه (فیات؛ مثل usd)
NOWPAYMENTS_PRICE_CURRENCY=usd
# ارز پرداخت پیش‌فرض (USDT روی شبکه‌ی BEP20 / BSC)
NOWPAYMENTS_PAY_CURRENCY=usdtbsc
# آدرس عمومی برای دریافت IPN (مثل https://دامنه:8090). برای شارژ خودکار لازم است.
PUBLIC_BASE_URL=

# --- پرداخت مستقیم کریپتو (USDT روی BEP20 / BSC) ---
# پول مستقیم به این آدرس واریز می‌شود؛ هیچ واسطه/فوروارد/فی انتقالی وجود ندارد.
# رصد فقط-خواندنی است؛ هیچ کلید خصوصی روی سرور ذخیره نمی‌شود.
CRYPTO_WALLET_ADDRESS=0x0E2D801A5A769d7C508C0602E70cec3D1386943D
# نقطه‌ی اتصال JSON-RPC شبکه‌ی BSC.
#  • تأیید دستی با هش تراکنش (eth_getTransactionReceipt) روی همین پیش‌فرض کار می‌کند.
#  • تأیید «خودکار» به RPCی نیاز دارد که eth_getLogs را پشتیبانی کند (اکثر RPCهای
#    عمومی رایگان محدودش می‌کنند). برای تأیید خودکار یک نود اختصاصی/سرویس
#    (QuickNode, Alchemy, Ankr و ...) اینجا بگذارید.
BSC_RPC_URL=https://bsc-dataseed.binance.org
# تعداد تأیید لازم قبل از تحویل (ضدتقلب/ری‌ارگ).
CRYPTO_CONFIRMATIONS=12
# مدت اعتبار هر فاکتور کریپتو به دقیقه.
CRYPTO_PAYMENT_TTL_MIN=60
# فعال/غیرفعال بودن هر روش پرداخت (در ربات هم قابل تغییر است).
PAY_CRYPTO_ENABLED=1
PAY_NOWPAYMENTS_ENABLED=1
# تأیید خودکار کریپتو؛ پیش‌فرض خاموش (تأیید با ارسال هش تراکنش انجام می‌شود).
CRYPTO_AUTOCONFIRM=0

# --- رفرال ---
# درصد پاداشی که به ازای هر خرید کاربرِ دعوت‌شده به کیف پول معرف اضافه می‌شود.
REFERRAL_PERCENT=5

# --- پلن V2Ray (یک‌ماهه نامحدود روی اینباند موجود) ---
# شناسه‌ی اینباند از پیش‌ساخته‌شده در پنل که کلاینت V2Ray در آن ساخته می‌شود.
V2RAY_INBOUND_ID=6
# مدت اعتبار پلن به روز (با هر تمدید از همان لحظه ریست می‌شود، نه افزودنی).
V2RAY_PLAN_DAYS=30
# قیمت ثابت پلن V2Ray یک‌ماهه‌ی نامحدود (USDT) — عادی و همکار.
V2RAY_PLAN_PRICE=5
V2RAY_PLAN_RESELLER_PRICE=3.5
IPN_HOST=0.0.0.0
IPN_PORT=8090
# برای فعال شدن HTTPS روی سرور IPN (NowPayments آدرس https لازم دارد).
# می‌توانید همان گواهی پنل را بدهید، مثلاً:
#   IPN_CERT_FILE=/root/cert/ddc.goldprem.ir/fullchain.pem
#   IPN_KEY_FILE=/root/cert/ddc.goldprem.ir/privkey.pem
IPN_CERT_FILE=
IPN_KEY_FILE=

# --- مسیر دیتابیس ---
DB_PATH=data/resibot.db
